// Waypoint data model — design reference for Phase 1.
// Prisma deps and migrations are wired up when the crawler lands;
// until then this file documents the intended schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // postgresql://waypoint:waypoint@localhost:5433/waypoint
}

model Source {
  id        String     @id // JobSource enum value, e.g. "remoteok"
  name      String
  enabled   Boolean    @default(true)
  jobs      Job[]
  crawlRuns CrawlRun[]
}

model CrawlRun {
  id            String   @id @default(cuid())
  sourceId      String
  source        Source   @relation(fields: [sourceId], references: [id])
  status        String // success | partial | failed
  startedAt     DateTime
  finishedAt    DateTime
  jobsFound     Int
  jobsNew       Int
  jobsDuplicate Int
  errors        Json     @default("[]")
}

model Job {
  id              String        @id @default(cuid())
  sourceId        String
  source          Source        @relation(fields: [sourceId], references: [id])
  externalId      String
  url             String
  title           String
  company         String
  location        String?
  workMode        String
  seniority       String
  salaryText      String?
  descriptionText String
  tags            String[]
  postedAt        DateTime?
  fetchedAt       DateTime
  dedupKey        String        @unique
  saved           Boolean       @default(false)
  hidden          Boolean       @default(false)
  // Phase 5: deterministic SWE/IT relevance (see classifyRelevance). Non-tech
  // roles (e.g. executive assistant, marketing) are flagged false and hidden
  // from the dashboard + skipped by the summarizer. Defaults true so a job is
  // never hidden before it's been classified; set by the extract pipeline and
  // the reclassify backfill. Reversible — never deletes the job.
  relevant        Boolean       @default(true)
  skills          JobSkill[]
  applications    Application[]
  summary         JobSummary?

  @@unique([sourceId, externalId])
}

// Phase 5 — LLM-generated structured analysis of a job posting. 1:1 with Job,
// kept as a separate table (nullable, regenerable, carries its own
// provenance) rather than columns on Job — same reasoning as JobSkill.
model JobSummary {
  jobId              String   @id
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  summary            String
  responsibilities   String[]
  requirements       String[]
  niceToHave         String[]
  benefits           String[]
  roleFunction       String // frontend | backend | fullstack | mobile | data | ml | devops | security | qa | pm | design | other
  yearsExperienceMin Int? // nullable; only set when ground-checked against the source text
  model              String // provenance, e.g. "gemma4:e4b"
  promptVersion      Int // bump to force re-generation after a prompt change
  sourceHash         String // hash(descriptionText); re-generate when the posting text changes
  generatedAt        DateTime @default(now())
}

model Skill {
  id       String     @id @default(cuid())
  name     String     @unique // canonical, e.g. "react"
  category String // language | framework | cloud | database | practice
  jobs     JobSkill[]
}

model JobSkill {
  jobId      String
  skillId    String
  confidence Float  @default(1)
  extractor  String // "rules" | "ollama"
  job        Job    @relation(fields: [jobId], references: [id])
  skill      Skill  @relation(fields: [skillId], references: [id])

  @@id([jobId, skillId])
}

// Single-row table: the project owner's profile, used for match scoring
// and roadmap generation. Always read/written via id "default".
model Profile {
  id                String   @id @default("default")
  skills            String[]
  yearsOfExperience Int
  targetSeniority   String
  targetWorkModes   String[]
  locations         String[]
  hoursPerWeek      Int      @default(8)
  updatedAt         DateTime @updatedAt
}

// Phase 3 — prep roadmap + spaced-repetition review.

model Track {
  id          String       @id // "dsa" | "system_design" | "cloud" | "web"
  name        String
  description String
  topics      Topic[]
  cards       ReviewCard[]
}

model Topic {
  id           String        @id @default(cuid())
  trackId      String
  track        Track         @relation(fields: [trackId], references: [id])
  slug         String        @unique
  name         String
  order        Int
  skills       String[] // taxonomy skill names that make this topic market-relevant
  difficulty   Int // 1-3
  resources    Resource[]
  roadmapItems RoadmapItem[]
}

model Resource {
  id         String  @id @default(cuid())
  topicId    String
  topic      Topic   @relation(fields: [topicId], references: [id])
  title      String
  url        String
  kind       String // article | video | course | problem_set | book_chapter
  note       String?
  estMinutes Int

  @@unique([topicId, url])
}

model RoadmapItem {
  id          String    @id @default(cuid())
  topicId     String
  topic       Topic     @relation(fields: [topicId], references: [id])
  weekIndex   Int
  status      String    @default("todo") // todo | in_progress | done
  reason      String // why it was scheduled, e.g. "kafka appears in 34% of JDs you can't cover"
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model ReviewCard {
  id        String  @id @default(cuid())
  contentId String  @unique // stable seed key, e.g. "dsa-arrays-hashing-01"
  trackId   String
  track     Track   @relation(fields: [trackId], references: [id])
  prompt    String
  answer    String
  topicSlug String?

  // SM-2 state
  easiness     Float    @default(2.5)
  intervalDays Int      @default(0)
  repetitions  Int      @default(0)
  dueAt        DateTime @default(now())
  lapses       Int      @default(0)

  logs ReviewLog[]
}

model ReviewLog {
  id               String     @id @default(cuid())
  cardId           String
  card             ReviewCard @relation(fields: [cardId], references: [id])
  grade            Int
  reviewedAt       DateTime   @default(now())
  previousInterval Int
  nextInterval     Int
}

// Phase 4 — application tracker.

model Application {
  id                String             @id @default(cuid())
  jobId             String? // null for manually-added applications not linked to a crawled job
  job               Job?               @relation(fields: [jobId], references: [id])
  company           String
  title             String
  url               String
  stage             String             @default("saved") // saved | applied | screening | interviewing | offer | rejected | withdrawn
  appliedAt         DateTime?
  nextActionAt      DateTime?
  nextActionNote    String?
  salaryExpectation String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  events            ApplicationEvent[]

  // Postgres unique constraints treat NULL as distinct, so this allows any
  // number of manual (jobId: null) applications while still enforcing at
  // most one tracked application per real job.
  @@unique([jobId])
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  kind          String // note | stage_change | interview
  body          String // markdown
  interviewKind String? // phone | technical | system_design | behavioral | final
  occurredAt    DateTime    @default(now())
}
