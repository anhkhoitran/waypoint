// Waypoint data model — design reference for Phase 1.
// Prisma deps and migrations are wired up when the crawler lands;
// until then this file documents the intended schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // postgresql://waypoint:waypoint@localhost:5433/waypoint
}

model Source {
  id        String     @id // JobSource enum value, e.g. "remoteok"
  name      String
  enabled   Boolean    @default(true)
  jobs      Job[]
  crawlRuns CrawlRun[]
}

model CrawlRun {
  id            String   @id @default(cuid())
  sourceId      String
  source        Source   @relation(fields: [sourceId], references: [id])
  status        String // success | partial | failed
  startedAt     DateTime
  finishedAt    DateTime
  jobsFound     Int
  jobsNew       Int
  jobsDuplicate Int
  errors        Json     @default("[]")
}

model Job {
  id              String     @id @default(cuid())
  sourceId        String
  source          Source     @relation(fields: [sourceId], references: [id])
  externalId      String
  url             String
  title           String
  company         String
  location        String?
  workMode        String
  seniority       String
  salaryText      String?
  descriptionText String
  tags            String[]
  postedAt        DateTime?
  fetchedAt       DateTime
  dedupKey        String     @unique
  saved           Boolean    @default(false)
  hidden          Boolean    @default(false)
  skills          JobSkill[]

  @@unique([sourceId, externalId])
}

model Skill {
  id       String     @id @default(cuid())
  name     String     @unique // canonical, e.g. "react"
  category String // language | framework | cloud | database | practice
  jobs     JobSkill[]
}

model JobSkill {
  jobId      String
  skillId    String
  confidence Float  @default(1)
  extractor  String // "rules" | "ollama"
  job        Job    @relation(fields: [jobId], references: [id])
  skill      Skill  @relation(fields: [skillId], references: [id])

  @@id([jobId, skillId])
}

// Single-row table: the project owner's profile, used for match scoring
// and (Phase 3) roadmap generation. Always read/written via id "default".
model Profile {
  id                String   @id @default("default")
  skills            String[]
  yearsOfExperience Int
  targetSeniority   String
  targetWorkModes   String[]
  locations         String[]
  updatedAt         DateTime @updatedAt
}
